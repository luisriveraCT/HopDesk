{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "OwnPrefixReadWrite",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject",
        "s3:GetObjectVersion",
        "s3:GetObjectVersionAcl",
        "s3:ListMultipartUploadParts",
        "s3:AbortMultipartUpload"
      ],
      "Resource": "arn:aws:s3:::BUCKET_NAME/CLIENT_ID/*"
    },
    {
      "Sid": "OwnPrefixList",
      "Effect": "Allow",
      "Action": "s3:ListBucket",
      "Resource": "arn:aws:s3:::BUCKET_NAME",
      "Condition": {
        "StringLike": {
          "s3:prefix": [
            "CLIENT_ID/*",
            "CLIENT_ID/"
          ]
        }
      }
    },
    {
      "Sid": "HdAdminSharedReadOnly",
      "Effect": "Allow",
      "Action": "s3:GetObject",
      "Resource": [
        "arn:aws:s3:::BUCKET_NAME/hd-admin/emergency_lock.rds",
        "arn:aws:s3:::BUCKET_NAME/hd-admin/username_index.rds",
        "arn:aws:s3:::BUCKET_NAME/hd-admin/client_registry.rds",
        "arn:aws:s3:::BUCKET_NAME/hd-admin/notifications.rds"
      ]
    },
    {
      "Sid": "BucketVersioningRead",
      "Effect": "Allow",
      "Action": "s3:GetBucketVersioning",
      "Resource": "arn:aws:s3:::BUCKET_NAME"
    },
    {
      "Sid": "DenyRootEnumeration",
      "Effect": "Deny",
      "Action": "s3:ListBucket",
      "Resource": "arn:aws:s3:::BUCKET_NAME",
      "Condition": {
        "StringNotLike": {
          "s3:prefix": [
            "CLIENT_ID/*",
            "CLIENT_ID/",
            ""
          ]
        }
      }
    }
  ]
}
